{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_EXAMPLES": "OFF",
        "BUILD_DX9": "OFF",
        "BUILD_DX11": "OFF",
        "BUILD_DX12": "OFF"
      }
    },
    {
      "name": "desktop-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "BUILD_GL": "ON",
        "BUILD_VULKAN": "ON",
        "USE_OPENGL3": "ON",
        "USE_OPENGLES3": "OFF"
      }
    },
    {
      "name": "macos-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "BUILD_GL": "ON",
        "BUILD_VULKAN": "OFF",
        "USE_OPENGL3": "ON",
        "USE_OPENGLES3": "OFF"
      }
    },
    {
      "name": "win-x64",
      "inherits": "desktop-base",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Windows"
      }
    },
    {
      "name": "linux-x64",
      "inherits": "desktop-base",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Linux"
      }
    },
    {
      "name": "macos-universal",
      "inherits": "macos-base",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Darwin",
        "CMAKE_OSX_ARCHITECTURES": "x86_64;arm64"
      }
    },
    {
      "name": "macos-x64",
      "inherits": "macos-base",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Darwin",
        "CMAKE_OSX_ARCHITECTURES": "x86_64"
      }
    },
    {
      "name": "macos-arm64",
      "inherits": "macos-base",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Darwin",
        "CMAKE_OSX_ARCHITECTURES": "arm64"
      }
    },
    {
      "name": "android-arm64",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Android",
        "CMAKE_TOOLCHAIN_FILE": "$env{ANDROID_NDK}/build/cmake/android.toolchain.cmake",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "24",
        "BUILD_GL": "ON",
        "BUILD_VULKAN": "OFF",
        "USE_OPENGL3": "OFF",
        "USE_OPENGLES3": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-win-release",
      "configurePreset": "win-x64"
    },
    {
      "name": "build-linux-release",
      "configurePreset": "linux-x64"
    },
    {
      "name": "build-macos-universal-release",
      "configurePreset": "macos-universal"
    },
    {
      "name": "build-macos-x64-release",
      "configurePreset": "macos-x64"
    },
    {
      "name": "build-macos-arm64-release",
      "configurePreset": "macos-arm64"
    },
    {
      "name": "build-android-release",
      "configurePreset": "android-arm64"
    }
  ]
}
